{
  "$schema": "../src/ai_guardian/schemas/ai-guardian-config.schema.json",
  "secret_scanning": {
    "enabled": true,
    "ignore_files": [
      "**/tests/fixtures/**",
      "**/tests/**/*.fixture.json",
      "**/examples/**/*.example.*",
      "**/.gitleaks.toml",
      "**/README.md",
      "**/CHANGELOG.md"
    ],
    "ignore_tools": []
  },
  "prompt_injection": {
    "enabled": true,
    "ignore_tools": ["Skill:code-review"],
    "ignore_files": [
      "**/.claude/skills/*/SKILL.md",
      "**/.claude/projects/**/tool-results/**"
    ]
  }
}
