# ai-guardian hook-testing image (NOT for distribution)
#
# Extends the base container image with bundled dummy-agent test scenarios.
# Scenarios are organized per profile: scenarios/standard/, scenarios/strict/,
# scenarios/minimal/, scenarios/moderator/
# Use this image for local CI regression and e2e hook testing only.
# Do NOT publish this image to a public registry.
#
# Build:
#   podman build -f container/Dockerfile.test -t ai-guardian-test container/
#   docker  build -f container/Dockerfile.test -t ai-guardian-test container/
#
# Run (default profile: standard):
#   podman run --rm ai-guardian-test /sandbox/run-scenarios.sh
#
# Run with a specific profile:
#   podman run --rm -e AI_GUARDIAN_PROFILE=strict    ai-guardian-test /sandbox/run-scenarios.sh
#   podman run --rm -e AI_GUARDIAN_PROFILE=minimal   ai-guardian-test /sandbox/run-scenarios.sh
#   podman run --rm -e AI_GUARDIAN_PROFILE=moderator ai-guardian-test /sandbox/run-scenarios.sh

ARG BASE_IMAGE=ai-guardian:latest
FROM ${BASE_IMAGE}

# Bundled hook test scenarios — organized by profile
USER root
COPY scenarios/ /sandbox/scenarios/
RUN chown -R sandbox:sandbox /sandbox/scenarios

# Scenario runner script — reads AI_GUARDIAN_PROFILE, writes per-profile
# config overlay, and runs all scenarios in scenarios/$PROFILE/
COPY run-scenarios.sh /sandbox/run-scenarios.sh
RUN chmod +x /sandbox/run-scenarios.sh \
    && chown sandbox:sandbox /sandbox/run-scenarios.sh

USER sandbox
