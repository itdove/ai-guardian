{
  "$schema": "https://raw.githubusercontent.com/itdove/ai-guardian/main/src/ai_guardian/schemas/tray-plugin.schema.json",
  "name": "Maintenance",
  "scope": "daemon",
  "items": [
    {
      "label": "Stop Daemon",
      "command": "ai-guardian daemon stop",
      "type": "notification"
    },
    {
      "label": "Restart Daemon",
      "command": "ai-guardian daemon restart",
      "type": "notification"
    },
    {
      "label": "Reload Config",
      "command": "ai-guardian daemon reload",
      "type": "notification"
    },
    {
      "label": "Install Scanner...",
      "command": "ai-guardian scanner install {tray.scanner}",
      "type": "terminal",
      "params": [
        {
          "name": "scanner",
          "hint": "Scanner engine to install",
          "type": "choice",
          "options": ["gitleaks", "betterleaks", "leaktk", "trufflehog", "detect-secrets"]
        }
      ]
    },
    {
      "label": "View Doctor",
      "command": {
        "darwin": "open http://127.0.0.1:$(cat ~/.local/state/ai-guardian/web-console.port)/{name}/health-check",
        "linux": "xdg-open http://127.0.0.1:$(cat ~/.local/state/ai-guardian/web-console.port)/{name}/health-check"
      },
      "type": "background"
    }
  ]
}
